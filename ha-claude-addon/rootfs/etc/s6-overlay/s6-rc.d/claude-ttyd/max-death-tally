#!/usr/bin/env bash

# TASK-007: Max death tally configuration for S6 watchdog service
# Controls how many consecutive failures before marking service as failed

DEFAULT_MAX_DEATH_TALLY=3

# Read max_death_tally from addon config if available, otherwise use default
MAX_DEATH_TALLY=$(cat /data/options.json 2>/dev/null | jq -r '.max_death_tally // empty')

# Validate the value and ensure it's a positive integer, use default if invalid or not set
if [ -n "$MAX_DEATH_TALLY" ] && [[ "$MAX_DEATH_TALLY" =~ ^[0-9]+$ ]] && [ "$MAX_DEATH_TALLY" -gt 0 ]; then
    echo "$MAX_DEATH_TALLY"
else
    echo "$DEFAULT_MAX_DEATH_TALLY"
fi
